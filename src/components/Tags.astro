---
interface Props {
  tags: string[];
  withHref?: boolean;
}

const { tags, withHref } = Astro.props;
---

<div class="flex flex-wrap">
  {
    tags.map((tag: string) => {
      const element = (
        <span class="mb-2 mr-2 rounded-xl bg-[#e3d0b8] px-3 py-1 text-xs font-bold uppercase text-[#032922] hover:bg-[#032922]">
          #{tag}
        </span>
      );
      return withHref ? <a href={`/tags/${tag}`}>{element}</a> : element;
    })
  }
</div>
